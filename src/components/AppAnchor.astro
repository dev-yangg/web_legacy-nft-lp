---
import BrandTitleSvg from "./BrandTitleSvg.astro";
import Logo from "./Logo.astro";

const { class: className } = Astro.props
---

<a href="/" aria-label="Go to homepage" class="inline-flex gap-[1ch] items-baseline ">
    <span class="inline-block w-9 aspect-square text-accent-mid">
        <Logo />
    </span>
    <span class="inline-block w-36 aspect-auto">
        <BrandTitleSvg />
    </span>
</a>