---

import PageHeader from "../components/PageHeader.astro";
import AppLayout from "../layouts/AppLayout.astro";
import collectionsHero from "../assets/images/collections/collections-hero.webp";
import collectionsHeroMobile from "../assets/images/collections/collections-hero-mobile.webp";
import CollectionsGallery from "../components/CollectionsGallery.astro";
import CollectionsHeaderActions from "../components/CollectionsHeaderActions.astro";
---

<AppLayout>
    <div class="md:page-padded-section-x relative">
        <PageHeader currentPage="Collections" headline="Timeless Collections." subheadline="Infinite Legacy." description="Handpicked NFT collections from visionary artists and builders. Own a piece of history, forever." image={collectionsHero} mobileImage={collectionsHeroMobile}/>
    </div>
    <section class="page-padded-section-x">
        <CollectionsHeaderActions />
        <CollectionsGallery />
    </section>
</AppLayout>