---
import PageHeader from "../components/PageHeader.astro";
import AppLayout from "../layouts/AppLayout.astro";
import aboutHero from "../assets/images/about/about-hero.webp"
import aboutHeroMobile from "../assets/images/about/about-hero-mobile.webp"
import { team } from "../data/team";
import { Image } from "astro:assets";

const aboutContent = {
  origin: {
    label: "OUR ORIGIN",
    paragraphs: [
      "Legacy was born from a simple belief: the things that truly matter should outlive us. In a world of fast trends and fleeting moments, we saw an opportunity to preserve art, ideas, and culture as digital legacies.",
      "We built Legacy to empower creators, protect collectors, and inspire generations — through technology that lasts."
    ],
  },
  coreValues: {
    label: "OUR CORE VALUES",
    items: [
      {
        title: "Timelessness",
        description: "We curate and build for lasting impact, not temporary hype."
      },
      {
        title: "Authenticity",
        description: "We protect originality and empower creators to stay true to their vision."
      },
      {
        title: "Trust",
        description: "Security, transparency, and fairness are the foundation of everything we do."
      },
      {
        title: "Legacy",
        description: "We exist to help culture endure and be passed down for generations."
      }
    ]
  }
};
---

<AppLayout>
        <PageHeader currentPage="About" headline="More than assets." subheadline="A Legacy." description="We are building the most trusted home for timeless digital assets — where history, culture, and ownership converge on the blockchain." image={aboutHero} mobileImage={aboutHeroMobile}/>
        <div class="absolute inset-x-4 bottom-0 opacity-35 bg-muted-subtle h-px"></div>



    <!-------------- Start of Content -------------->
    <section class=" page-padded-section flex flex-col md:grid md:grid-cols-[.15fr_1fr] gap-8 relative isolate py-14">

        <!-------------- Overlays & Background -------------->
        <div aria-hidden="true" class="absolute inset-0 -z-10">
            <div class="absolute inset-0 about-overlay -z-10"></div>
            <div class="absolute inset-0 bg-base/65"></div>
            <div class="absolute inset-0 bg-linear-90 from-55% from-base to-65% to-transparent"></div>
            <div class="absolute inset-y-0 right-0 w-1/2 bg-radial from-transparent from-20% to-base/75 to-90%"></div>
        </div>


        <!-------------- Origin -------------->
            <header class="pt-1 text-nowrap">
                <small class="text-accent font-semibold flex gap-[4ch]">
                    <span>{aboutContent.origin.label}</span> 
                    <span class="text-muted opacity-35">———</span>
                </small>
            </header>
            <section class="w-fluid-width-md md:text-balance flex flex-col gap-4 md:pr-4">
                {aboutContent.origin.paragraphs.map((content) => (
                    <p class="text-muted-strong ">{content}</p>
                ))}
            </section>


        <!-------------- Core Values -------------->
            <header class="pt-1 text-nowrap">
                <small class="text-accent font-semibold flex gap-[4ch]">
                    <span>{aboutContent.coreValues.label}</span> 
                    <span class="text-muted opacity-35">———</span>
                </small>
            </header>
            <section class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
                {aboutContent.coreValues.items.map((value,index) => (
                    <article class="flex flex-col py-3 px-4 bg-base/55 outline-1 outline-muted-subtle/35 rounded-md">
                        <small class="text-accent">{`${String(index + 1).padStart(2, "0")}`}</small>
                        <strong class="font-playfair">{value.title}</strong>
                        <p class="text-muted-strong mt-2 md:text-small text-balance">{value.description}</p>
                    </article>
                ))}
            </section>
    </section>

    <!-------------- Team -------------->
     <section class="page-padded-section-x flex flex-col gap-4">
        <header class="pt-1 text-nowrap">
            <small class="text-accent font-semibold flex gap-[4ch]">
                <span>Our Team</span> 
                <span class="text-muted opacity-35">———</span>
            </small>
        </header>
        <section class="grid grid-cols-1 mobile:grid-cols-2 lg:grid-cols-4 gap-4">
               {team.map((member) => (
                    <figure class="grid grid-cols-1 outline-1 outline-muted-subtle/35 rounded-md overflow-clip isolate">
                        <div class="col-start-1 col-end-2 row-start-1">
                            <Image 
                                src={member.image} 
                                alt={member.name} 
                                width={member.image.width} 
                                height={member.image.height} 
                                format="webp" 
                                quality={80} 
                                loading="lazy" 
                                class="w-full h-full object-cover grayscale contrast-105 brightness-85" 
                            />
                        </div>
                        <figcaption class="col-start-1 col-end-2 row-start-1 z-10 flex flex-col self-end justify-self-end pr-3 pb-3">
                            <span class="font-semibold max-sm:text-small">{member.name}</span>
                            <small class="text-muted-strong max-sm:text-tiny">{member.role}</small>
                        </figcaption>
                    </figure>
                ))}
        </section>
    </section>
</AppLayout>



<style>
    .about-overlay {
        background: url('../assets/images/about/about-section-overlay.webp');
        background-repeat: no-repeat;
        background-size: cover;
        background-position: center;
    }
</style>